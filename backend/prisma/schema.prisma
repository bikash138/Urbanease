generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum ProviderStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewStatus {
  VISIBLE
  FLAGGED
  HIDDEN
}

enum AddressLabel {
  HOME
  WORK
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ImageType {
  BEFORE
  AFTER
}

enum SlotLabel {
  MORNING
  AFTERNOON
  NIGHT
}

model User {
  id                 String             @id @default(uuid())
  name               String
  email              String             @unique
  passwordHash       String
  role               Role
  phone              String?
  isActive           Boolean            @default(true)
  reviewGiven        Review[]
  refreshToken       RefreshToken[]
  passwordResetToken PasswordResetToken?

  customerProfile CustomerProfile?
  providerProfile ProviderProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model CustomerProfile {
  id        String    @id @default(uuid())
  addresses Address[]
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ProviderProfile {
  id           String  @id @default(uuid())
  slug         String  @unique
  bio          String?
  experience   Int?
  profileImage String

  status          ProviderStatus @default(PENDING)
  rejectionReason String?
  averageRating   Float?
  reviewCount     Int            @default(0)
  reviewsGained   Review[]

  userId          String            @unique
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  servicesOffered ProviderService[]

  providerSlots ProviderSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model ProviderService {
  id          String  @id @default(uuid())
  customPrice Float?
  isAvailable Boolean @default(true)

  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  bookings    Booking[]
  serviceArea ProviderServiceArea[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, serviceId])
  @@index([serviceId, isAvailable])
  @@index([providerId])
}

model Address {
  id        String       @id @default(uuid())
  label     AddressLabel
  street    String
  city      String
  state     String
  pincode   String
  isDefault Boolean      @default(false)

  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]

  @@index([customerId])
}

model Booking {
  id           String        @id @default(uuid())
  status       BookingStatus @default(PENDING)
  startedAt    DateTime?
  completedAt  DateTime?
  totalAmount  Float
  customerNote String?
  providerNote String?
  date         DateTime      @db.Date

  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Restrict)

  providerServiceId String
  providerService   ProviderService @relation(fields: [providerServiceId], references: [id], onDelete: Restrict)

  addressId String
  address   Address @relation(fields: [addressId], references: [id], onDelete: Restrict)

  slotId String
  slot   ProviderSlot @relation(fields: [slotId], references: [id])

  images BookingImage[]
  review Review?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerServiceId, slotId, date])
  @@index([customerId])
  @@index([providerServiceId])
}

model BookingImage {
  id        String    @id @default(uuid())
  url       String
  type      ImageType
  bookingId String
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([bookingId])
}

model ServiceCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  image       String
  isActive    Boolean @default(true)

  services Service[]

  createdAt DateTime @default(now())

  @@index([isActive])
}

model Service {
  id          String  @id @default(uuid())
  title       String
  slug        String  @unique
  description String?
  basePrice   Float
  image       String
  isActive    Boolean @default(false)

  categoryId String
  category   ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  providers ProviderService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, isActive])
}

model Review {
  id      String       @id @default(uuid())
  rating  Int
  comment String?
  status  ReviewStatus @default(VISIBLE)

  customerId String
  customer   User   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([status])
}

model ProviderSlot {
  id String @id @default(uuid())

  providerSlug String
  date         DateTime
  slot         SlotLabel

  totalSlots  Int
  bookedSlots Int @default(0)

  provider ProviderProfile @relation(fields: [providerSlug], references: [slug])

  bookings Booking[]

  @@unique([providerSlug, date, slot])
}

model Area {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  city     String
  state    String
  isActive Boolean @default(true)

  providerServiceArea ProviderServiceArea[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProviderServiceArea {
  providerServiceId String
  providerService   ProviderService @relation(fields: [providerServiceId], references: [id], onDelete: Cascade)
  areaId            String
  area              Area            @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([providerServiceId, areaId])
}
