# =============================================================================
# Server
# =============================================================================
NODE_ENV=development
PORT=4000

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/urbanease

# =============================================================================
# Redis / Valkey (caching, rate limiting — use a redis: URL)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Frontend
# CORS origin; also used to build password-reset links in emails.
# Next.js should set NEXT_PUBLIC_API_URL to this backend (e.g. http://localhost:4000).
# =============================================================================
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Auth — JWT & token secrets
# =============================================================================
JWT_ACCESS_SECRET=your-jwt-access-secret-min-4-chars
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-4-chars
PASSWORD_RESET_SECRET=your-password-reset-pepper-min-1-char

JWT_EXPIRES_IN=7d

# Access JWT lifetime (e.g. 30s, 15m, 1h)
JWT_ACCESS_EXPIRES_IN=30m

# Refresh token lifetime in whole days (cookie + DB expiresAt)
REFRESH_TOKEN_EXPIRES_IN=7

# =============================================================================
# Auth — admin sign-in (/auth/admin-signin)
# =============================================================================
ADMIN_KEY=your-admin-secret-key

# =============================================================================
# Auth — cookies (optional)
# Production: set when frontend and API share a parent domain, e.g. .yourdomain.com
# =============================================================================
# COOKIE_DOMAIN=

# =============================================================================
# AWS S3 (image uploads)
# =============================================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_ENDPOINT_URL_S3=https://s3.amazonaws.com
AWS_ENDPOINT_URL_IAM=https://iam.amazonaws.com
AWS_REGION=us-east-1
S3_BUCKET_NAME=urbanease-bucket

# =============================================================================
# Email (Resend — transactional, password reset)
# =============================================================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Urbanease <noreply@yourdomain.com>
